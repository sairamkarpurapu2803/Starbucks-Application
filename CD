pipeline {
    agent any

    tools {
        jdk 'jdk17'
        nodejs 'node16'
    }

    stages {

        stage("Deploy to Container") {
            steps {
                script {
                    // Stop & remove old container (if exists)
                    sh """
                    if [ \$(docker ps -aq -f name=sairam) ]; then
                        docker rm -f sairam
                    fi
                    """

                    // Run latest container
                    sh """
                    docker run -d --name sairam -p 3000:3000 saicloud28/starbucks:latest
                    """
                }
            }
        }

    }
}
